local URL = "https://raw.githubusercontent.com/HFK1554vb/Mam-pothe/main/Teleport"

-- Xoá GUI cũ nếu có
local core = game:GetService("CoreGui")
if core:FindFirstChild("TeleportAutoLoader") then
    core.TeleportAutoLoader:Destroy()
end

-- GUI tối giản
local gui = Instance.new("ScreenGui")
gui.Name = "TeleportAutoLoader"
gui.ResetOnSpawn = false
gui.Parent = core

local label = Instance.new("TextLabel")
label.Size = UDim2.new(0, 220, 0, 60)
label.Position = UDim2.new(0.5, -110, 0.4, 0)
label.BackgroundColor3 = Color3.fromRGB(25,25,25)
label.TextColor3 = Color3.new(1,1,1)
label.TextScaled = true
label.Text = "Loading..."
label.Parent = gui

Instance.new("UICorner", label).CornerRadius = UDim.new(0,15)

-- LOAD NGAY LẬP TỨC
local success, err = pcall(function()
    loadstring(game:HttpGet(URL))()
end)

-- Huỷ GUI ngay sau khi load xong
gui:Destroy()

if not success then
    warn(err)
end
