local URL = "https://raw.githubusercontent.com/HFK1554vb/Mam-pothe/main/Teleport"

local TweenService = game:GetService("TweenService")

if game:GetService("CoreGui"):FindFirstChild("TeleportAutoLoader") then
    game:GetService("CoreGui").TeleportAutoLoader:Destroy()
end

local gui = Instance.new("ScreenGui")
gui.Name = "TeleportAutoLoader"
gui.ResetOnSpawn = false
gui.Parent = game:GetService("CoreGui")

local frame = Instance.new("Frame")
frame.Size = UDim2.new(0, 320, 0, 120)
frame.Position = UDim2.new(0.5, -160, 0.4, -60)
frame.BackgroundColor3 = Color3.fromRGB(25,25,25)
frame.Parent = gui

Instance.new("UICorner", frame).CornerRadius = UDim.new(0, 20)

local stroke = Instance.new("UIStroke", frame)
stroke.Color = Color3.fromRGB(60,60,60)
stroke.Thickness = 1.5

local barBG = Instance.new("Frame")
barBG.Size = UDim2.new(0.9, 0, 0.08, 0)
barBG.Position = UDim2.new(0.05, 0, 0.08, 0)
barBG.BackgroundColor3 = Color3.fromRGB(45,45,45)
barBG.Parent = frame
Instance.new("UICorner", barBG).CornerRadius = UDim.new(1,0)

local bar = Instance.new("Frame")
bar.Size = UDim2.new(0, 0, 1, 0)
bar.BackgroundColor3 = Color3.fromRGB(0,170,255)
bar.Parent = barBG
Instance.new("UICorner", bar).CornerRadius = UDim.new(1,0)

local title = Instance.new("TextLabel")
title.Size = UDim2.new(1, 0, 0.6, 0)
title.Position = UDim2.new(0, 0, 0.3, 0)
title.BackgroundTransparency = 1
title.Text = "Loading Teleport..."
title.TextColor3 = Color3.new(1,1,1)
title.TextScaled = true
title.Parent = frame

-- Tween chạy
TweenService:Create(
    bar,
    TweenInfo.new(1.5, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
    {Size = UDim2.new(1, 0, 1, 0)}
):Play()

task.spawn(function()

    local success, response = pcall(function()
        return game:HttpGet(URL)
    end)

    if success and response and #response > 0 then
        title.Text = "Loaded ✓"
        pcall(function()
            loadstring(response)()
        end)
    else
        title.Text = "Failed ✗"
        bar.BackgroundColor3 = Color3.fromRGB(200,60,60)
    end

    task.wait(1.2)

    -- Destroy luôn không phụ thuộc tween
    if gui then
        gui:Destroy()
    end

end)
local bgCorner = Instance.new("UICorner")
bgCorner.CornerRadius = UDim.new(1,0)
bgCorner.Parent = barBG

-- Thanh chạy
local bar = Instance.new("Frame")
bar.Size = UDim2.new(0, 0, 1, 0)
bar.BackgroundColor3 = Color3.fromRGB(0,170,255)
bar.Parent = barBG

local barCorner = Instance.new("UICorner")
barCorner.CornerRadius = UDim.new(1,0)
barCorner.Parent = bar

-- Gradient chạy
local gradient = Instance.new("UIGradient")
gradient.Color = ColorSequence.new{
    ColorSequenceKeypoint.new(0, Color3.fromRGB(0,170,255)),
    ColorSequenceKeypoint.new(0.5, Color3.fromRGB(0,255,200)),
    ColorSequenceKeypoint.new(1, Color3.fromRGB(0,170,255))
}
gradient.Parent = bar

-- Text
local title = Instance.new("TextLabel")
title.Size = UDim2.new(1, 0, 0.6, 0)
title.Position = UDim2.new(0, 0, 0.3, 0)
title.BackgroundTransparency = 1
title.Text = "Loading Teleport..."
title.TextColor3 = Color3.new(1,1,1)
title.TextScaled = true
title.Parent = frame

-- Animation đổ
local tween = TweenService:Create(
    bar,
    TweenInfo.new(1.5, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
    {Size = UDim2.new(1, 0, 1, 0)}
)

tween:Play()

-- Load song song
task.spawn(function()

    local success, response = pcall(function()
        return game:HttpGet(URL)
    end)

    tween.Completed:Wait()

    if success and response and #response > 0 then
        title.Text = "Loaded ✓"
        loadstring(response)()
    else
        title.Text = "Failed ✗"
        bar.BackgroundColor3 = Color3.fromRGB(200,60,60)
    end

    task.wait(1)

    -- Fade mềm
    for i = 0,1,0.08 do
        frame.BackgroundTransparency = i
        title.TextTransparency = i
        barBG.BackgroundTransparency = i
        bar.BackgroundTransparency = i
        stroke.Transparency = i
        task.wait(0.03)
    end

    gui:Destroy()

end)
