stroke.Parent = button

-------------------------------------------------
-- HOLD TO DRAG (GIỮ NGUYÊN)
-------------------------------------------------

local HOLD_TIME = 0
local DRAG_COOLDOWN = 10

local holding = false
local holdStart = 0
local dragging = false
local lastMoveTime = 0
local clickEnabled = true

button.MouseButton1Down:Connect(function()
	holding = true
	holdStart = tick()

	task.spawn(function()
		while holding do
			if tick() - holdStart >= HOLD_TIME then
				button.Draggable = true
				dragging = true
				break
			end
			task.wait()
		end
	end)
end)

button.MouseButton1Up:Connect(function()
	holding = false
	button.Draggable = false
	dragging = false
	task.wait(0.1)
	clickEnabled = true
end)

button:GetPropertyChangedSignal("Position"):Connect(function()
	if dragging then
		lastMoveTime = tick()
		clickEnabled = false
	end
end)

RunService.Heartbeat:Connect(function()
	if not clickEnabled and tick() - lastMoveTime >= DRAG_COOLDOWN then
		clickEnabled = true
	end
end)

-------------------------------------------------
-- TARGET SYSTEM
-------------------------------------------------

local function getHRP(character)
	if not character then return nil end
	return character:FindFirstChild("HumanoidRootPart")
end

local function isValid(character)
	if not character then return false end
	
	local humanoid = character:FindFirstChildOfClass("Humanoid")
	local hrp = character:FindFirstChild("HumanoidRootPart")

	if not humanoid or not hrp then return false end
	if humanoid.Health <= 0 then return false end
	
	return true
end

local function findNearest()
	local myChar = player.Character
	if not isValid(myChar) then return nil end
	
	local myHRP = getHRP(myChar)
	if not myHRP then return nil end

	local nearest = nil
	local minDist = math.huge

	for _, plr in ipairs(Players:GetPlayers()) do
		if plr ~= player and plr.Character and isValid(plr.Character) then
			
			local hrp = getHRP(plr.Character)
			if hrp then
				local dist = (myHRP.Position - hrp.Position).Magnitude
				if dist < minDist then
					minDist = dist
					nearest = hrp
				end
			end
		end
	end

	return nearest
end

-------------------------------------------------
-- FOLLOW LOGIC
-------------------------------------------------

local toggled = false
local connection = nil
local currentTarget = nil
local oldPosition = nil
local lastTargetPosition = nil

local MAX_SELF_VELOCITY = 120
local MAX_TELEPORT_DISTANCE = 60
local MAX_VELOCITY = 150

local function setCollision(character, state)
	for _,v in ipairs(character:GetDescendants()) do
		if v:IsA("BasePart") then
			v.CanCollide = state
		end
	end
end

button.MouseButton1Click:Connect(function()

	if not clickEnabled then return end

	local char = player.Character or player.CharacterAdded:Wait()
	local hrp = char:WaitForChild("HumanoidRootPart")

	-- TẮT
	if toggled then
		toggled = false
		button.Text = "T"

		if connection then
			connection:Disconnect()
			connection = nil
		end

		setCollision(char,true)
		camera.CameraSubject = char:FindFirstChildOfClass("Humanoid")

		if oldPosition then
			hrp.CFrame = oldPosition
		end
		
		return
	end

	-- BẬT
	currentTarget = findNearest()
	if not currentTarget then return end

	oldPosition = hrp.CFrame
	lastTargetPosition = currentTarget.Position

	toggled = true
	button.Text = "S"
	setCollision(char,false)

	connection = RunService.Heartbeat:Connect(function()

		if not currentTarget
			or not currentTarget.Parent
			or not currentTarget.Parent:FindFirstChildOfClass("Humanoid")
			or currentTarget.Parent:FindFirstChildOfClass("Humanoid").Health <= 0 then
			
			toggled = false
			button.Text = "T"

			if connection then
				connection:Disconnect()
				connection = nil
			end

			setCollision(char,true)
			return
		end

		local currentPos = currentTarget.Position

		if hrp.AssemblyLinearVelocity.Magnitude > MAX_SELF_VELOCITY then
			hrp.AssemblyLinearVelocity = Vector3.zero
		end



		lastTargetPosition = currentPos

		if currentTarget.AssemblyLinearVelocity.Magnitude > MAX_VELOCITY then
			toggled = false
			button.Text = "T"

			connection:Disconnect()
			connection = nil
			setCollision(char,true)
			return
		end

		local ping = math.clamp(player:GetNetworkPing(),0.05,0.3)
		local velocity = currentTarget.AssemblyLinearVelocity

		local predicted = currentPos + velocity * ping
		local behind = predicted - (currentTarget.CFrame.LookVector * 3)

		hrp.CFrame = CFrame.new(behind, predicted)
		camera.CameraSubject = currentTarget.Parent:FindFirstChildOfClass("Humanoid")

	end)
end)

player.CharacterAdded:Connect(function()
	toggled = false
	if connection then
		connection:Disconnect()
		connection = nil
	end
	button.Text = "T"
	currentTarget = nil
end)
